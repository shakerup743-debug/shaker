    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "http-proxy-middleware": "^4.0.0",
    "jose": "^6.2.3",
    "js-yaml": "^4.1.1",
    "otpauth": "^9.5.1",
    "pg": "^8.20.0",
    "pino": "^9",
    "pino-http": "^10",
